# GitHub Actions Workflow for Automated Database Updates
#
# This is an EXAMPLE workflow. To use it:
# 1. Rename to update-database.yml
# 2. Set up OIDC (see scripts/S3_SETUP.md)
# 3. Add database credentials as GitHub secrets
# 4. Update YOUR_ACCOUNT_ID with your AWS account ID

name: Update Sequence Database

on:
  workflow_dispatch:  # Manual trigger via GitHub UI

  # Uncomment to run on schedule (weekly on Sunday at midnight UTC)
  # schedule:
  #   - cron: '0 0 * * 0'

  # Uncomment to run when database schema changes
  # push:
  #   paths:
  #     - 'database/migrations/**'

permissions:
  id-token: write   # Required for AWS OIDC authentication
  contents: read

jobs:
  update-database:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install Python dependencies
        run: |
          pip install -r scripts/requirements.txt

      - name: Install MMseqs2
        run: |
          wget -q https://mmseqs.com/latest/mmseqs-linux-avx2.tar.gz
          tar xzf mmseqs-linux-avx2.tar.gz
          echo "$PWD/mmseqs/bin" >> $GITHUB_PATH

      - name: Verify MMseqs2 installation
        run: |
          mmseqs version

      - name: Configure AWS credentials (OIDC)
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::YOUR_ACCOUNT_ID:role/GitHubActionsS3Upload
          aws-region: us-east-1

      - name: Verify AWS credentials
        run: |
          aws sts get-caller-identity

      - name: Update sequence database
        env:
          DB_HOST: ${{ secrets.DB_HOST }}
          DB_NAME: ${{ secrets.DB_NAME }}
          DB_USER: ${{ secrets.DB_USER }}
          DB_PASSWORD: ${{ secrets.DB_PASSWORD }}
          DB_PORT: ${{ secrets.DB_PORT || '5432' }}
        run: |
          python scripts/update_sequence_index.py

      - name: Notify on success
        if: success()
        run: |
          echo "✓ Database updated successfully!"
          echo "Check S3 bucket: petadex-sequence-db"

      - name: Notify on failure
        if: failure()
        run: |
          echo "✗ Database update failed!"
          echo "Check the logs above for details"

